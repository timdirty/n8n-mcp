# ============================================
# STEAM 比賽資訊蒐集系統 - 環境變數配置
# ============================================

# ----------------
# Google Sheets 配置
# ----------------
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com

# Google Sheets 工作表名稱
SHEET_NAME_COMPETITIONS=STEAM_Competitions
SHEET_NAME_ERROR_LOG=Error_Log
SHEET_NAME_MONITORING=Monitoring_Dashboard
SHEET_NAME_REVIEW=Review_Queue

# ----------------
# LINE Messaging API 配置
# ----------------
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# LINE 群組 ID（單一群組 - MVP）
LINE_GROUP_ID=your_line_group_id_here

# LINE 多群組配置（進階版）
LINE_GROUP_ELEMENTARY=group_id_for_elementary
LINE_GROUP_JUNIOR=group_id_for_junior
LINE_GROUP_SENIOR=group_id_for_senior
LINE_GROUP_TEACHER=group_id_for_teacher

# ----------------
# 資料源配置
# ----------------
# 教育部 RSS
EDU_RSS_URL=https://www.edu.tw/rss.aspx

# 政府開放資料平台
GOV_API_URL=https://data.gov.tw/api/v2/rest/dataset/search
GOV_API_KEY=

# 科技部
MOST_API_URL=https://www.most.gov.tw/api/activities
MOST_API_KEY=

# 科教館
NTSEC_API_URL=https://www.ntsec.gov.tw/api/events
NTSEC_API_KEY=

# ----------------
# OpenAI 配置（完整版需要）
# ----------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.3

# ----------------
# Email 配置（進階版）
# ----------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@your-domain.com
EMAIL_TO=admin@your-domain.com

# ----------------
# Telegram 配置（進階版）
# ----------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ----------------
# Notion 配置（完整版）
# ----------------
NOTION_API_KEY=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# ----------------
# 執行配置
# ----------------
# 定時執行時間（Cron 表達式）
SCHEDULE_CRON=0 8 * * *

# 是否在啟動時執行
TRIGGER_AT_STARTUP=false

# 執行超時時間（毫秒）
EXECUTION_TIMEOUT=300000

# ----------------
# 功能開關
# ----------------
# 啟用 AI 分類
ENABLE_AI_CLASSIFICATION=false

# 啟用 AI 摘要
ENABLE_AI_SUMMARY=false

# 啟用多群組分流
ENABLE_MULTI_GROUP=false

# 啟用人工審核
ENABLE_MANUAL_REVIEW=false

# 啟用 Flex Message
ENABLE_FLEX_MESSAGE=false

# 啟用 Email 通知
ENABLE_EMAIL_NOTIFICATION=false

# 啟用 Telegram 通知
ENABLE_TELEGRAM_NOTIFICATION=false

# 啟用 Notion 同步
ENABLE_NOTION_SYNC=false

# ----------------
# 進階配置
# ----------------
# 資料保留天數
DATA_RETENTION_DAYS=365

# 排程間隔（小時）
SCHEDULE_HOURS=6

# 去重時間窗口（天）
DEDUP_TIME_WINDOW_DAYS=7

# 去重標題相似度閾值 (0-1)
DEDUP_TITLE_THRESHOLD=0.85

# 去重內容相似度閾值 (0-1)
DEDUP_CONTENT_THRESHOLD=0.90

# 最大重試次數
MAX_RETRY_ATTEMPTS=3

# 重試間隔（毫秒）
RETRY_INTERVAL_MS=2000

# API 請求超時（毫秒）
API_TIMEOUT_MS=15000

# 批次處理大小（LINE API 限速，建議 5）
BATCH_SIZE=5

# 啟用多群組推播
LINE_MULTI_GROUP=false

# ----------------
# 監控與日誌
# ----------------
# 日誌級別（debug, info, warn, error）
LOG_LEVEL=info

# 啟用詳細日誌
ENABLE_VERBOSE_LOGGING=false

# 錯誤通知閾值
ERROR_NOTIFICATION_THRESHOLD=5

# 監控報告頻率（天）
MONITORING_REPORT_FREQUENCY_DAYS=7

# ----------------
# 主題模板配置
# ----------------
# 當前主題（steam_competition, summer_camp, teacher_training, government_grant, education_event）
CURRENT_TOPIC=steam_competition

# ----------------
# 安全配置
# ----------------
# Webhook 驗證 Token
WEBHOOK_VERIFY_TOKEN=your_random_secure_token_here

# API 速率限制（請求/分鐘）
RATE_LIMIT_PER_MINUTE=60

# ----------------
# 開發/測試配置
# ----------------
# 開發模式
NODE_ENV=production

# 測試模式（不實際推送訊息）
TEST_MODE=false

# 乾跑模式（只記錄不執行）
DRY_RUN=false
